# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ----- App -----
# Public URL where your app is deployed. Used in tracking links and unsubscribe URLs.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ----- Secrets (generate with: openssl rand -hex 32) -----
# Encrypts SMTP/IMAP passwords at rest. Rotating this invalidates all stored creds.
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32
# Signs tracking pixel / click / unsubscribe URLs. Falls back to ENCRYPTION_KEY if unset.
TRACKING_SECRET=GENERATE_WITH_openssl_rand_hex_32
# Bearer token required by /api/cron and /api/cron/imap. Set the same value in Supabase pg_cron.
CRON_SECRET=GENERATE_WITH_openssl_rand_hex_32

# ----- Optional -----
# MAIL FROM address used by the email-verifier SMTP probe. Use a real domain you control.
VERIFIER_PROBE_FROM=verify@your-domain.com
